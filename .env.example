# ============================================================
# TELEGRAM CONFIGURATION
# ============================================================
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram chat/channel ID (use @userinfobot to find it)
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================================
# SCRAPER SETTINGS
# ============================================================
# Run interval in minutes (default: 30)
RUN_INTERVAL_MINUTES=30

# Max jobs to fetch per source per run
MAX_JOBS_PER_SOURCE=50

# Headless browser mode (true/false). Set false to debug visually.
HEADLESS=true

# ============================================================
# PROXY (optional - leave blank to disable)
# ============================================================
# HTTP_PROXY=http://user:pass@host:port
# HTTPS_PROXY=https://user:pass@host:port

# ============================================================
# ADVANCED
# ============================================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Days to look back for job postings
LOOKBACK_DAYS=1

# Database path
DB_PATH=data/jobs.db

# Health check interval in hours (weekly = 168)
HEALTH_CHECK_INTERVAL_HOURS=168
