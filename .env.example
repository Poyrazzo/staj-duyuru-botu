# ============================================================
# TELEGRAM CONFIGURATION
# ============================================================
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram chat/channel ID (use @userinfobot to find it)
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================================
# SCRAPER SETTINGS
# ============================================================
# Run interval in minutes (default: 180 / 3 hours)
RUN_INTERVAL_MINUTES=180

# Max jobs to fetch per source per run
MAX_JOBS_PER_SOURCE=50

# Max companies queried by the DuckDuckGo safety-net scraper per run
DDG_COMPANY_QUERY_LIMIT=80
DDG_COMPANY_CONCURRENCY=4

# Headless browser mode (true/false). Set false to debug visually.
HEADLESS=true

# ============================================================
# GOOGLE CUSTOM SEARCH (optional but recommended — daily safety net)
# Catches any internship page the scrapers might miss.
# Free: 100 queries/day (enough for ~70 company domains).
#
# Setup (5 minutes):
# 1. console.cloud.google.com → New project → Enable "Custom Search API"
#    → Credentials → Create API Key → paste below
# 2. cse.google.com → New search engine → turn ON "Search the entire web"
#    → Copy the "Search engine ID" → paste below
# ============================================================
GOOGLE_CSE_API_KEY=your_google_api_key_here
GOOGLE_CSE_CX=your_search_engine_id_here

# ============================================================
# PROXY (optional - leave blank to disable)
# ============================================================
# HTTP_PROXY=http://user:pass@host:port
# HTTPS_PROXY=https://user:pass@host:port

# ============================================================
# ADVANCED
# ============================================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Days to look back for job postings
LOOKBACK_DAYS=1

# Database path
DB_PATH=data/jobs.db

# Health check interval in hours (weekly = 168)
HEALTH_CHECK_INTERVAL_HOURS=168
